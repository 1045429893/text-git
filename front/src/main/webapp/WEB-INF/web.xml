<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://java.sun.com/xml/ns/javaee" xmlns:jsp="http://java.sun.com/xml/ns/javaee/jsp"
	xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
	version="2.5">
	<display-name>front</display-name>
	<listener>
		<listener-class>com.hd.util.SystemListener</listener-class>
	</listener>
	<context-param>
		<param-name>contextConfigLocation</param-name>
		<param-value>classpath:applicationContext.xml</param-value>
	</context-param>

	<listener>
		<listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
	</listener>
	<servlet>
		<servlet-name>x</servlet-name>
		<servlet-class>com.hd.common.servlet.EncodingDispatcherServlet</servlet-class>
		<init-param>
			<param-name>encoding</param-name>
			<param-value>UTF-8</param-value>
		</init-param>
		<load-on-startup>2</load-on-startup>
	</servlet>
	<servlet-mapping>
		<servlet-name>x</servlet-name>
		<url-pattern>/index</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>x</servlet-name>
		<url-pattern>*.do</url-pattern>
	</servlet-mapping>

	<welcome-file-list>
		<welcome-file>index</welcome-file>
	</welcome-file-list>

	<filter>
		<filter-name>sessionFilter</filter-name>
		<filter-class>com.hd.Filter.SessionFilter</filter-class>
		<init-param>
			<param-name>excludedPages</param-name>
			<param-value>/mall/shoppingCart/goShoppingCartList.do,/mall/shoppingCart/addShoppingCart.do,/mall/shoppingCart/addShoppingCartBuyNow.do,/mall/myMall/goMallIndex.do</param-value>
		</init-param>
		<init-param>
			<param-name>smsExcludedPages</param-name>
			<param-value>/sms/user/sendMessageCode.do,/sms/user/getSendMessageAuthImg.do,/sms/user/getAuthImg.do,/sms/user/goSmsIndex.do,/sms/user/goSmsUserLogin.do,/sms/user/smsUserLogin.do</param-value>
		</init-param>
	</filter>
	<filter-mapping>
		<filter-name>sessionFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

	<session-config>
		<session-timeout>720</session-timeout>
	</session-config>

	<filter>
		<filter-name>XssSqlFilter</filter-name>
		<filter-class>com.hd.util.XssFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>XssSqlFilter</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
</web-app>